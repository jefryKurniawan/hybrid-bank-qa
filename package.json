{
  "name": "hybrid-bank-qa",
  "version": "1.0.0",
  "description": "QA portfolio: Hybrid banking system — Bank Indonesia (Web2) + USDC on-chain (Web3) + CEX/Wallet integration",
  "scripts": {
    "setup": "npx hardhat compile && tsx scripts/seed.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "dev": "tsx backend/src/index.ts",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand --forceExit",
    "test:coverage": "jest --runInBand --coverage --forceExit",
    "test:integration": "jest --runInBand --testPathPattern=integration --forceExit",
    "test:e2e": "npx playwright test",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,json,sol}\"",
    "hardhat:compile": "npx hardhat compile",
    "hardhat:test": "npx hardhat test",
    "hardhat:node": "npx hardhat node",
    "hardhat:deploy": "npx hardhat run scripts/deploy.ts --network localhost",
    "coverage:solidity": "npx hardhat coverage",
    "coverage:typescript": "jest --runInBand --coverage --forceExit"
  },
  "keywords": [
    "qa",
    "banking",
    "blockchain",
    "usdc",
    "hybrid",
    "testing"
  ],
  "author": "jefryKurniawan",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "ethers": "6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4.3.20",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "hardhat": "^2.28.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  }
}
