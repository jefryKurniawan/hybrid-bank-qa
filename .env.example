# Hybrid Bank QA — Environment Variables
# Copy to .env and fill in values (never commit .env)

# Server
PORT=3000
NODE_ENV=test

# Blockchain
HARDHAT_NETWORK=localhost
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Mock USDC Contract (populated after deploy)
MOCK_USDC_ADDRESS=

# Bank Settings
BI_FAST_CUTOFF_HOUR=16
BI_FAST_CUTOFF_TIMEZONE=Asia/Jakarta

# CEX Settings
SPREAD_THRESHOLD=0.02

# Webhook
WEBHOOK_URL=http://localhost:3000/webhook
